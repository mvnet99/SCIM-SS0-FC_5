        </mxCell>
        <mxCell id="leg2" value="outbound — us to Customer API&#xa;(OAuth + service account header)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#107C10;" vertex="1" parent="1">
          <mxGeometry x="52" y="402" width="220" height="28" as="geometry" />
