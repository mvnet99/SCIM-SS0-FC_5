          <mxGeometry x="52" y="436" width="220" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="The SCIM API stores nothing.&#xa;It translates and forwards.&#xa;&#xa;KeyVaultUrl is the only environment&#xa;variable. Everything else comes&#xa;from the vault at startup." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#333333;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="52" y="462" width="220" height="90" as="geometry" />
        </mxCell>

        <!-- ============ NOTE ============ -->
        <mxCell id="note" value="Deployment: azure-pipeline-ci.yml builds, azure-pipeline-cd.yml releases.&#xa;Both are thin wrappers — the real templates live in the DevOpsPipelineTemplates repo, release branch.&#xa;&#xa;Customer_Groups and Customer_Group_Regions are seeded by WIS_Database/Scripts/PS_SSO_Config.sql.&#xa;The SCIM API only ever reads them, via POST /api/users/SearchCustomerGroups." style="text;html=1;strokeColor=#CCCCCC;fillColor=#FFFDE7;align=left;verticalAlign=top;fontSize=10;whiteSpace=wrap;rounded=1;spacingLeft=8;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="640" y="560" width="500" height="90" as="geometry" />
        </mxCell>

